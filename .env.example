# ── Copy to .env and fill in real values ────────────────────────────────────

# LiteLLM master key — set to any secret string, used by all services
LITELLM_MASTER_KEY=sk-finagent-local

# Cloud models (optional — leave blank to run fully local/free)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Models ────────────────────────────────────────────────────────────────
# Chat: Qwen3-30B-A3B — MoE, 3B active params, Apache 2.0
# RTX 4060 8 GB: fits with ~22 GB RAM offload; inference fast due to MoE
PRIMARY_MODEL=qwen3-30b-a3b

# Embedding: nomic-embed-text — local via Ollama, 768 dims, no API key needed
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Open WebUI admin
WEBUI_ADMIN_PASSWORD=change-me

# Ingestion — SEC EDGAR (required; use your real email per SEC fair-use policy)
SEC_USER_AGENT=FinAgent/1.0 your@email.com

# Ingestion — CourtListener (optional; raises daily rate limit from 5k to 100k)
COURTLISTENER_TOKEN=

# Internal service hostnames (leave as-is for Docker Compose)
REDIS_HOST=redis-stack
REDIS_PORT=6379
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
LITELLM_BASE_URL=http://litellm:4000/v1
