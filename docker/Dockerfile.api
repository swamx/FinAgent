FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    python -m spacy download en_core_web_sm && \
    python -c "\
import pathlib; \
p = next(pathlib.Path('/usr/local/lib').glob('python3.*/site-packages/pydantic_ai/usage.py')); \
src = p.read_text(); \
old = 'self.details[key] = self.details.get(key, 0) + value'; \
new = 'self.details[key] = self.details.get(key, 0) + (sum(v for v in value.values() if isinstance(v, int)) if isinstance(value, dict) else int(value))'; \
p.write_text(src.replace(old, new)); \
print(f'Patched pydantic_ai/usage.py at {p}') \
"

COPY . .

CMD ["uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
