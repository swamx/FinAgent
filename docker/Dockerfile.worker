FROM python:3.12-slim

WORKDIR /app

# System deps for lxml + torch (GLiNER)
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc g++ libxml2-dev libxslt-dev curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    python -m spacy download en_core_web_sm

# Pre-download GLiNER model weights during build so container starts fast
RUN python -c "from gliner import GLiNER; GLiNER.from_pretrained('urchade/gliner_mediumv2.1')" || true

COPY . .

CMD ["python", "-m", "apps.worker.ingestion_worker"]
