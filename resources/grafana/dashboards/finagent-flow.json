{
  "uid": "finagent-flow",
  "title": "FinAgent — Request Flow",
  "description": "End-to-end trace: query → entity resolve → graph expand → vector search → LLM → response",
  "tags": ["finagent", "flow", "traces"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },

  "panels": [

    { "type": "row", "title": "── Overview ──────────────────────────────────────────────────────────", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 1, "type": "stat", "title": "Chat Requests / min",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "reqpm" } },
      "targets": [{ "expr": "rate(http_server_request_duration_milliseconds_count{http_route=\"/chat\"}[1m]) * 60", "legendFormat": "chat" }]
    },

    {
      "id": 2, "type": "stat", "title": "p95 End-to-end Latency",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } } },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(finagent_llm_duration_seconds_bucket[5m]))", "legendFormat": "LLM p95" }]
    },

    {
      "id": 3, "type": "stat", "title": "Tool Calls / min",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] }, "unit": "short" } },
      "targets": [{ "expr": "sum(rate(finagent_agent_tool_calls_total[1m])) * 60", "legendFormat": "tools/min" }]
    },

    {
      "id": 4, "type": "stat", "title": "Avg Entities / Query",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "expr": "rate(finagent_retrieval_entities_per_query_sum[5m]) / rate(finagent_retrieval_entities_per_query_count[5m])", "legendFormat": "avg entities" }]
    },

    {
      "id": 5, "type": "stat", "title": "Avg Docs / Query",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "teal", "value": null }] } } },
      "targets": [{ "expr": "rate(finagent_retrieval_docs_per_query_sum[5m]) / rate(finagent_retrieval_docs_per_query_count[5m])", "legendFormat": "avg docs" }]
    },

    {
      "id": 6, "type": "stat", "title": "LLM Errors",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "increase(finagent_llm_errors_total[5m])", "legendFormat": "errors" }]
    },

    { "type": "row", "title": "── Stage Latency (per-stage breakdown of a request) ──────────────────────", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 10, "type": "timeseries", "title": "Stage Latency — p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 6, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(finagent_search_duration_seconds_bucket[2m]))", "legendFormat": "Search p50" },
        { "expr": "histogram_quantile(0.95, rate(finagent_search_duration_seconds_bucket[2m]))", "legendFormat": "Search p95" },
        { "expr": "histogram_quantile(0.50, rate(finagent_graph_query_duration_seconds_bucket[2m]))", "legendFormat": "Graph p50" },
        { "expr": "histogram_quantile(0.95, rate(finagent_graph_query_duration_seconds_bucket[2m]))", "legendFormat": "Graph p95" },
        { "expr": "histogram_quantile(0.50, rate(finagent_llm_duration_seconds_bucket[2m]))", "legendFormat": "LLM p50" },
        { "expr": "histogram_quantile(0.95, rate(finagent_llm_duration_seconds_bucket[2m]))", "legendFormat": "LLM p95" },
        { "expr": "histogram_quantile(0.99, rate(finagent_llm_duration_seconds_bucket[2m]))", "legendFormat": "LLM p99" }
      ]
    },

    {
      "id": 11, "type": "bargauge", "title": "Avg Stage Latency",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "color": { "mode": "continuous-BlPu" } } },
      "targets": [
        { "expr": "rate(finagent_graph_query_duration_seconds_sum[5m]) / rate(finagent_graph_query_duration_seconds_count[5m])", "legendFormat": "Graph query" },
        { "expr": "rate(finagent_search_duration_seconds_sum[5m]) / rate(finagent_search_duration_seconds_count[5m])", "legendFormat": "Hybrid search" },
        { "expr": "rate(finagent_embed_duration_seconds_sum[5m]) / rate(finagent_embed_duration_seconds_count[5m])", "legendFormat": "Embed" },
        { "expr": "rate(finagent_llm_duration_seconds_sum[5m]) / rate(finagent_llm_duration_seconds_count[5m])", "legendFormat": "LLM completion" }
      ]
    },

    { "type": "row", "title": "── Tool Call Distribution ────────────────────────────────────────────────", "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 20, "type": "timeseries", "title": "Tool Calls / min by Tool",
      "gridPos": { "x": 0, "y": 15, "w": 14, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"] } },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "search_documents" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }, { "id": "displayName", "value": "search_documents" }] },
          { "matcher": { "id": "byName", "options": "get_entity"       }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }, { "id": "displayName", "value": "get_entity"       }] },
          { "matcher": { "id": "byName", "options": "get_exposure"     }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FADE2A" } }, { "id": "displayName", "value": "get_exposure"     }] },
          { "matcher": { "id": "byName", "options": "expand_entity"    }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }, { "id": "displayName", "value": "expand_entity"    }] }
        ]
      },
      "targets": [
        { "expr": "rate(finagent_agent_tool_calls_total[1m]) * 60", "legendFormat": "{{tool}}" }
      ]
    },

    {
      "id": 21, "type": "piechart", "title": "Tool Call Share (window)",
      "gridPos": { "x": 14, "y": 15, "w": 10, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "displayLabels": ["percent", "name"], "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        { "expr": "increase(finagent_agent_tool_calls_total[1h])", "legendFormat": "{{tool}}" }
      ]
    },

    { "type": "row", "title": "── Trace Explorer (Tempo) ────────────────────────────────────────────────", "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 30, "type": "traces", "title": "Live Traces — finagent-api",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 12 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{
        "queryType": "nativeSearch",
        "serviceName": "finagent-api",
        "spanName": "",
        "search": "",
        "minDuration": "",
        "maxDuration": "",
        "limit": 20,
        "refId": "A"
      }]
    },

    { "type": "row", "title": "── Logs ──────────────────────────────────────────────────────────────────", "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 40, "type": "logs", "title": "Tool Call Logs",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{
        "expr": "{service_name=\"finagent-api\"} |= \"tool_call\"",
        "refId": "A"
      }]
    }

  ]
}
